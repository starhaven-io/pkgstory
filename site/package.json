{
  "name": "pkgstory-site",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=26.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "check:headers": "node scripts/check-security-headers.mjs",
    "prebuild": "node scripts/check-security-headers.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "wrangler deploy --config dist/server/wrangler.json",
    "deploy:dry": "npm run deploy -- --dry-run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.2",
    "@astrojs/rss": "^4.0.19",
    "astro": "^7.0.4"
  },
  "devDependencies": {
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "wrangler": "^4.106.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "allowScripts": {
    "esbuild": true,
    "fsevents": true,
    "sharp": true,
    "workerd": true
  }
}
