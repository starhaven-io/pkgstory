---
export const prerender = false;

import Base from "../layouts/Base.astro";

// SSR so the status is a real 404 — both for unmatched routes (the adapter serves
// this page) and for a missing package (the detail page rewrites here).
Astro.response.status = 404;
---

<Base title="Not found — pkgstory" description="Page not found.">
  <div class="notfound">
    <h2>404</h2>
    <p>
      That page isn't here — the URL may be mistyped. Try searching from the <a
        href="/">home page</a
      >.
    </p>
  </div>

  <style>
    .notfound {
      padding: 2.5rem 0;
    }
    .notfound h2 {
      font-size: 2.4rem;
      color: var(--accent);
      margin: 0 0 0.4rem;
      text-transform: none;
      letter-spacing: 0;
    }
    .notfound p {
      color: var(--muted);
    }
  </style>
</Base>
