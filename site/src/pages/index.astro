---
export const prerender = false;

import Base from '../layouts/Base.astro';
import Chip from '../components/Chip.astro';
import StatusChip from '../components/StatusChip.astro';
import Version from '../components/Version.astro';
import { home } from '../lib/cache.ts';
import { displayVersion, isoDate } from '../lib/format.ts';

const { formulae, casks, spotlight, recent, checkedAt } = await home();
const total = formulae + casks;
const lastCheckedAt = checkedAt;
const packagePath = (source: string, name: string) => `/${source}/${encodeURIComponent(name)}/`;

// Short edge cache so the home page stays cheap between crawls (~30 min apart).
Astro.response.headers.set('cache-control', 'public, max-age=300, s-maxage=600');
---

<Base
  title="pkgstory"
  tagline="Every package has a version story."
  description="Browse the version history of every Homebrew formula and cask — updates over time, with per-package RSS."
  lastCheckedAt={lastCheckedAt}
>
  <section class="home-intro" aria-labelledby="home-title">
    <div class="intro-copy">
      <p class="intro-kicker">Homebrew version history</p>
      <h2 id="home-title" class="intro-title">Search package histories</h2>
      <p class="scope">
        Tracking <b>Homebrew</b> formulae and casks across version changes, lifecycle states, removals, migrations, and renames.
      </p>
    </div>
    <dl class="metric-strip">
      <div class="metric">
        <dt>Total</dt>
        <dd>{total.toLocaleString()}</dd>
      </div>
      <div class="metric">
        <dt>Formulae</dt>
        <dd>{formulae.toLocaleString()}</dd>
      </div>
      <div class="metric">
        <dt>Casks</dt>
        <dd>{casks.toLocaleString()}</dd>
      </div>
      <div class="metric">
        <dt>Shown</dt>
        <dd>{recent.length.toLocaleString()} latest</dd>
      </div>
    </dl>
  </section>

  <section class="search-panel" aria-labelledby="search-title">
    <label id="search-title" class="search-label" for="q">Search packages</label>
    <input
      id="q"
      class="search"
      type="search"
      placeholder={`Search ${total.toLocaleString()} packages …`}
      autocomplete="off"
      autocapitalize="off"
      spellcheck="false"
    />
    <div id="results" class="results" hidden></div>
  </section>

  {
    spotlight.length > 0 && (
      <section class="spotlight" aria-labelledby="spotlight-title">
        <div class="section-head">
          <h2 id="spotlight-title">Interesting histories</h2>
        </div>
        <div class="spotlight-grid">
          {spotlight.map((p) => (
            <a class="spotlight-card" href={packagePath(p.source, p.name)}>
              <span class="spotlight-kicker">{p.title}</span>
              <span class="spotlight-topline">
                <span class="spotlight-name">{p.name}</span>
                {p.x && <StatusChip code={p.x} />}
              </span>
              <span class="spotlight-stat">{p.stat}</span>
              <span class="spotlight-note">{p.note}</span>
              <span class="spotlight-meta">
                <span
                  class="spotlight-current"
                  title={p.version ? displayVersion(p.version, p.revision) : 'no version'}
                >
                  {p.version ? <Version version={p.version} revision={p.revision} /> : 'no version'}
                </span>
                <span class="spotlight-context">{p.context}</span>
              </span>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <section id="recent">
    <div class="section-head">
      <h2>Recent updates</h2>
      <p>{recent.length.toLocaleString()} latest version changes</p>
    </div>
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>Updated</th>
            <th>Package</th>
            <th>Version</th>
            <th>Kind</th>
          </tr>
        </thead>
        <tbody>
          {
            recent.map((c) => (
              <tr>
                <td class="date">{isoDate(c.introducedAt)}</td>
                <td>
                  <div class="pkg-cell">
                    <a class="pkg-link" href={packagePath(c.source, c.name)}>
                      {c.name}
                    </a>
                    {c.x && <StatusChip code={c.x} />}
                  </div>
                </td>
                <td>
                  <Version version={c.version} revision={c.revision} />
                </td>
                <td class="kind-cell">
                  <Chip source={c.source} />
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <script>
    const input = document.getElementById('q') as HTMLInputElement | null;
    const results = document.getElementById('results');
    const recentEl = document.getElementById('recent');
    if (input && results && recentEl) {
      interface Pkg {
        n: string;
        s: string;
        v: string | null;
        r: number;
        c: number;
        x?: 'n' | 'm' | 'r' | 'x' | 'd';
      }
      const STATUS: Record<string, [string, string]> = {
        n: ['renamed', 'chip-renamed'],
        m: ['migrated', 'chip-migrated'],
        r: ['removed', 'chip-removed'],
        x: ['disabled', 'chip-disabled'],
        d: ['deprecated', 'chip-deprecated'],
      };
      let data: Pkg[] | null = null;
      const esc = (s: string) =>
        s.replace(/[&<>"]/g, (ch) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[ch] ?? ch);
      const load = async (): Promise<Pkg[]> => {
        if (!data) data = await (await fetch('/packages.json')).json();
        return data ?? [];
      };
      // Warm the ~1 MB index while the user is still reaching for their first key.
      input.addEventListener('focus', () => void load(), { once: true });
      const rowHtml = (p: Pkg): string => {
        const kind = p.s === 'c' ? 'cask' : 'formula';
        const src = p.s === 'c' ? 'homebrew-cask' : 'homebrew-formula';
        const ver = p.v ? (p.r ? `${p.v}_${p.r}` : p.v) : '';
        const st = p.x && STATUS[p.x] ? ` <span class="chip ${STATUS[p.x][1]}">${STATUS[p.x][0]}</span>` : '';
        return `<tr><td><div class="pkg-cell"><a class="pkg-link" href="/${src}/${encodeURIComponent(p.n)}/">${esc(p.n)}</a>${st}</div></td><td class="kind-cell"><span class="chip chip-${kind}">${kind}</span></td><td class="ver">${esc(ver)}</td><td class="num">${p.c}</td></tr>`;
      };
      input.addEventListener('input', async () => {
        const q = input.value.trim().toLowerCase();
        if (!q) {
          results.hidden = true;
          results.innerHTML = '';
          recentEl.hidden = false;
          return;
        }
        const all = await load();
        const matches = all.filter((p) => p.n.toLowerCase().includes(q));
        matches.sort((a, b) => {
          const ap = a.n.toLowerCase().startsWith(q);
          const bp = b.n.toLowerCase().startsWith(q);
          if (ap !== bp) return ap ? -1 : 1;
          return a.n.length - b.n.length || a.n.localeCompare(b.n);
        });
        const shown = matches.slice(0, 100);
        const note = `${matches.length.toLocaleString()} match${matches.length === 1 ? '' : 'es'}${matches.length > 100 ? ' · showing 100' : ''}`;
        results.innerHTML = `<div class="section-head"><h2>Search results</h2><p>${note}</p></div><div class="table-scroll"><table><thead><tr><th>Package</th><th>Kind</th><th>Version</th><th>Events</th></tr></thead><tbody>${shown.map(rowHtml).join('')}</tbody></table></div>`;
        recentEl.hidden = true;
        results.hidden = false;
      });
    }
  </script>
</Base>
