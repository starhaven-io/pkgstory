---
import { isoDate, lifecycleState, plusYear, todayISO } from '../lib/format.ts';

// The end-of-life banner on a package page. Renders nothing while active (including
// future-scheduled stanzas). The current state is derived from both deprecate!/disable!
// stanzas against today, and the next transition is projected ~1 year on — the cadence
// Homebrew follows (deprecate → disable → remove).
interface Props {
  name: string;
  removedAt: number | null;
  removedCommit: string | null;
  renamedTo: string | null;
  migratedTo: string | null;
  deprecateDate: string | null;
  deprecateReason: string | null;
  disableDate: string | null;
  disableReason: string | null;
  repo: string; // e.g. "homebrew/homebrew-core" — for the removal-commit link + tap name
  lastVersion: string | null;
}
const {
  name,
  removedAt,
  removedCommit,
  renamedTo,
  migratedTo,
  deprecateDate,
  deprecateReason,
  disableDate,
  disableReason,
  repo,
  lastVersion,
} = Astro.props;

const state = lifecycleState(
  {
    removedAt,
    removedCommit,
    renamedTo,
    migratedTo,
    deprecateDate,
    deprecateReason,
    disableDate,
    disableReason,
  },
  todayISO(),
);
const tap = repo.endsWith('cask') ? 'Homebrew/cask' : 'Homebrew/core';
const commitUrl = removedCommit ? `https://github.com/${repo}/commit/${removedCommit}` : null;
const source = repo.endsWith('cask') ? 'homebrew-cask' : 'homebrew-formula';
const targetHref = renamedTo ? `/${source}/${encodeURIComponent(renamedTo)}/` : null;

function migrationTarget(target: string): { label: string; href: string | null } {
  if (target === 'homebrew/core')
    return { label: 'Homebrew/core', href: `/homebrew-formula/${encodeURIComponent(name)}/` };
  if (target === 'homebrew/cask')
    return { label: 'Homebrew/cask', href: `/homebrew-cask/${encodeURIComponent(name)}/` };
  if (target.startsWith('homebrew/core/')) {
    const migratedName = target.slice('homebrew/core/'.length);
    return { label: `Homebrew/core/${migratedName}`, href: `/homebrew-formula/${encodeURIComponent(migratedName)}/` };
  }
  if (target.startsWith('homebrew/cask/')) {
    const migratedName = target.slice('homebrew/cask/'.length);
    return { label: `Homebrew/cask/${migratedName}`, href: `/homebrew-cask/${encodeURIComponent(migratedName)}/` };
  }
  return { label: target, href: null };
}

const migration = migratedTo ? migrationTarget(migratedTo) : null;

// The stanza in effect (or, for a removed package, the last one it carried before going).
const onDisable = state === 'disabled' || (state === 'removed' && (disableDate != null || disableReason != null));
const stageWord = onDisable ? 'disabled' : 'deprecated';
const stageDate = onDisable ? disableDate : deprecateDate;
const stageReason = onDisable ? disableReason : deprecateReason;
const on = stageDate ? ` on ${stageDate}` : '';
const why = stageReason ? ` because it ${stageReason}` : '';

const removedStage =
  onDisable || deprecateDate != null || deprecateReason != null ? `${name} was ${stageWord}${on}${why}. ` : '';
const removedText = `Deleted from ${tap} on ${isoDate(removedAt ?? 0)}. ${removedStage}${
  lastVersion ? `The final version shipped in ${tap} was ${lastVersion}.` : ''
}`;
const disabledText = `${name} was disabled in ${tap}${on}${why}.${
  disableDate ? ` It will be removed from ${tap} around ${plusYear(disableDate)}.` : ''
}`;
// A deprecated package will be disabled on its scheduled disable date, else ~1 year on.
const cutoff = disableDate ?? (deprecateDate ? plusYear(deprecateDate) : null);
const deprecatedText = `${name} was deprecated in ${tap}${on}${why}.${
  cutoff ? ` It will no longer be able to be installed after ${cutoff}.` : ''
}`;
---

{
  state !== 'active' && (
    <aside class:list={['banner', `banner-${state}`]}>
      <span class="banner-tag">{state}</span>
      <span class="banner-text">
        {state === 'renamed' && (
          <>
            {name} was renamed in {tap}
            {renamedTo && <> to {targetHref ? <a href={targetHref}>{renamedTo}</a> : <>{renamedTo}</>}</>} on{' '}
            {isoDate(removedAt ?? 0)}.{lastVersion && <> The final version under this name was {lastVersion}.</>}
            {commitUrl && (
              <>
                {' '}
                <a href={commitUrl}>rename commit ↗</a>
              </>
            )}
          </>
        )}
        {state === 'migrated' && (
          <>
            {name} was migrated from {tap}
            {migration && (
              <> to {migration.href ? <a href={migration.href}>{migration.label}</a> : <>{migration.label}</>}</>
            )}{' '}
            on {isoDate(removedAt ?? 0)}.
            {lastVersion && (
              <>
                {' '}
                The final version in {tap} was {lastVersion}.
              </>
            )}
            {commitUrl && (
              <>
                {' '}
                <a href={commitUrl}>migration commit ↗</a>
              </>
            )}
          </>
        )}
        {state === 'removed' && (
          <>
            {removedText}
            {commitUrl && (
              <>
                {' '}
                <a href={commitUrl}>removal commit ↗</a>
              </>
            )}
          </>
        )}
        {state === 'disabled' && disabledText}
        {state === 'deprecated' && deprecatedText}
      </span>
    </aside>
  )
}
