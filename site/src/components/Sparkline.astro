---
interface Props {
  dates: number[]; // unix seconds
  from: number; // window start (unix seconds)
  to: number; // window end (unix seconds)
  bins?: number;
  width?: number;
  height?: number;
  title?: string;
}
const {
  dates,
  from,
  to,
  bins = 24,
  width = 104,
  height = 24,
  title,
} = Astro.props;

const span = Math.max(1, to - from);
const counts = new Array<number>(bins).fill(0);
for (const d of dates) {
  if (d < from || d > to) continue;
  const i = Math.min(
    bins - 1,
    Math.max(0, Math.floor(((d - from) / span) * bins)),
  );
  counts[i] += 1;
}
const max = Math.max(1, ...counts);
const gap = 1;
const barW = (width - gap * (bins - 1)) / bins;
---

<svg
  class="spark"
  width={width}
  height={height}
  viewBox={`0 0 ${width} ${height}`}
  preserveAspectRatio="none"
  role="img"
  aria-label={title ?? "release cadence"}
>
  {
    counts.map((c, i) => {
      const h = c === 0 ? 1.5 : Math.max(2, (c / max) * height);
      return (
        <rect
          x={i * (barW + gap)}
          y={height - h}
          width={barW}
          height={h}
          rx="0.5"
          class:list={["spark-bar", { "spark-empty": c === 0 }]}
        />
      );
    })
  }
</svg>
